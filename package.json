{
  "name": "@video-share/admin-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:local": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "preview:local": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "echo \"TODO_TEST: Admin web tests will be added later\"",
    "format": "prettier --ignore-path ../../.prettierignore --write \"src/**/*.{ts,tsx,css,json}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --ignore-path ../../.prettierignore --check \"src/**/*.{ts,tsx,css,json}\" \"*.{ts,js,json}\"",
    "check": "yarn typecheck && yarn lint && yarn format:check && yarn build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/google-sans": "^5.2.1",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-redux": "^9.3.0",
    "react-router": "^7.16.0",
    "react-router-dom": "^7.16.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "shadcn": "^4.9.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
